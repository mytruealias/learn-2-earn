generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Path {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String   @default("")
  icon        String   @default("📘")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  modules     Module[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Module {
  id        String   @id @default(cuid())
  pathId    String
  title     String
  slug      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)

  path      Path     @relation(fields: [pathId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@unique([pathId, slug])
}

model Lesson {
  id        String   @id @default(cuid())
  moduleId  String
  title     String
  slug      String
  order     Int      @default(0)
  xpReward  Int      @default(10)
  type      String   @default("learn")
  isActive  Boolean  @default(true)

  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  cards     Card[]
  progress  Progress[]

  @@unique([moduleId, slug])
}

model Card {
  id          String    @id @default(cuid())
  lessonId    String
  type        String
  order       Int       @default(0)

  prompt      String
  body        String?
  mediaUrl    String?

  choicesJson String?
  answerJson  String?
  explain     String?

  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model User {
  id            String   @id @default(cuid())
  guestId       String?  @unique
  email         String?  @unique
  passwordHash  String?
  fullName      String?
  dateOfBirth   String?
  phone         String?
  city          String?
  state         String?
  zipCode       String?
  caseNumber    String?
  emergencyContactName  String?
  emergencyContactPhone String?
  isActive      Boolean  @default(true)
  hearts        Int      @default(5)
  totalXp       Int      @default(0)
  streak        Int      @default(0)
  streakFreezes Int      @default(1)
  lastFreezeUsedAt DateTime?
  lastActiveAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  consentGiven  Boolean  @default(false)
  consentAt     DateTime?
  progress      Progress[]
  payoutRequests PayoutRequest[]
  consents      ConsentRecord[]
  cases         Case[]
}

model Progress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  xpEarned    Int      @default(0)
  crownLevel  Int      @default(1)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

enum PaymentMethod {
  venmo
  paypal
  cashapp
  check
}

model PayoutRequest {
  id            String         @id @default(cuid())
  userId        String
  xpAmount      Int
  dollarAmount  Float
  status        String         @default("pending")
  note          String?
  paymentMethod PaymentMethod?
  paymentHandle String?
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNote    String?
  approvedById  String?
  approvedAt    DateTime?
  decisionNote  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy    AdminUser?   @relation("PayoutReviewer", fields: [reviewedById], references: [id])
  approvedBy    AdminUser?   @relation("PayoutApprover", fields: [approvedById], references: [id])
}

model AdminUser {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  fullName        String
  role            String    @default("caseworker")
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  lastLoginAt     DateTime?
  loginFailures   Int       @default(0)
  lockedUntil     DateTime?

  reviewedPayouts  PayoutRequest[]    @relation("PayoutReviewer")
  approvedPayouts  PayoutRequest[]    @relation("PayoutApprover")
  auditLogs        AuditLog[]
  sessions         AdminSession[]
  assignedCases    Case[]             @relation("CaseAssignee")
  caseNotes        CaseNote[]
  resourceAllocations ResourceAllocation[]
  poolAdjustments  PoolAdjustment[]
}

model Case {
  id           String   @id @default(cuid())
  userId       String
  status       String   @default("new")
  priority     String   @default("medium")
  title        String
  message      String
  assignedToId String?
  location     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo   AdminUser? @relation("CaseAssignee", fields: [assignedToId], references: [id])
  notes        CaseNote[]
  allocations  ResourceAllocation[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model CaseNote {
  id        String   @id @default(cuid())
  caseId    String
  adminId   String
  text      String
  type      String   @default("note")
  createdAt DateTime @default(now())

  case      Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  admin     AdminUser @relation(fields: [adminId], references: [id])

  @@index([caseId])
}

model ResourceAllocation {
  id           String   @id @default(cuid())
  caseId       String
  adminId      String
  resourceType String
  quantity     Int      @default(1)
  notes        String?
  createdAt    DateTime @default(now())

  case         Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  admin        AdminUser @relation(fields: [adminId], references: [id])

  @@index([caseId])
}

model ServiceDirectory {
  id        String   @id @default(cuid())
  name      String
  category  String
  address   String?
  phone     String?
  hours     String?
  notes     String?
  website   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  adminId   String
  admin     AdminUser @relation(fields: [adminId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([adminId])
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String?
  action      String
  entity      String
  entityId    String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  admin       AdminUser? @relation(fields: [adminId], references: [id])

  @@index([entity, entityId])
  @@index([adminId])
  @@index([createdAt])
}

model ConsentRecord {
  id          String   @id @default(cuid())
  userId      String
  consentType String
  version     String   @default("1.0")
  granted     Boolean  @default(true)
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PoolBalance {
  id          String   @id @default(cuid())
  balanceCents Int     @default(0)
  updatedAt   DateTime @updatedAt
  updatedById String?
}

model PoolAdjustment {
  id          String   @id @default(cuid())
  adminId     String
  amountCents Int
  reason      String
  createdAt   DateTime @default(now())

  admin       AdminUser @relation(fields: [adminId], references: [id])

  @@index([createdAt])
}
