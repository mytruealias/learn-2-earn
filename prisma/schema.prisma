generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Path {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String   @default("")
  icon        String   @default("📘")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  modules     Module[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Module {
  id        String   @id @default(cuid())
  pathId    String
  title     String
  slug      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)

  path      Path     @relation(fields: [pathId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@unique([pathId, slug])
}

model Lesson {
  id        String   @id @default(cuid())
  moduleId  String
  title     String
  slug      String
  order     Int      @default(0)
  xpReward  Int      @default(10)
  type      String   @default("learn")
  isActive  Boolean  @default(true)

  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  cards     Card[]
  progress  Progress[]

  @@unique([moduleId, slug])
}

model Card {
  id          String    @id @default(cuid())
  lessonId    String
  type        String
  order       Int       @default(0)

  prompt      String
  body        String?
  mediaUrl    String?

  choicesJson String?
  answerJson  String?
  explain     String?

  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model User {
  id            String   @id @default(cuid())
  guestId       String?  @unique
  email         String?  @unique
  passwordHash  String?
  fullName      String?
  dateOfBirth   String?
  phone         String?
  city          String?
  state         String?
  zipCode       String?
  caseNumber    String?
  emergencyContactName  String?
  emergencyContactPhone String?
  hearts        Int      @default(5)
  totalXp       Int      @default(0)
  streak        Int      @default(0)
  lastActiveAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  consentGiven  Boolean  @default(false)
  consentAt     DateTime?
  progress      Progress[]
  payoutRequests PayoutRequest[]
  consents      ConsentRecord[]
}

model Progress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  xpEarned    Int      @default(0)
  crownLevel  Int      @default(1)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model PayoutRequest {
  id            String   @id @default(cuid())
  userId        String
  xpAmount      Int
  dollarAmount  Float
  status        String   @default("pending")
  note          String?
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNote    String?
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy    AdminUser?   @relation("PayoutReviewer", fields: [reviewedById], references: [id])
  approvedBy    AdminUser?   @relation("PayoutApprover", fields: [approvedById], references: [id])
}

model AdminUser {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  fullName      String
  role          String   @default("caseworker")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  lastLoginAt   DateTime?

  reviewedPayouts  PayoutRequest[] @relation("PayoutReviewer")
  approvedPayouts  PayoutRequest[] @relation("PayoutApprover")
  auditLogs        AuditLog[]
  sessions         AdminSession[]
}

model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  adminId   String
  admin     AdminUser @relation(fields: [adminId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([adminId])
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String?
  action      String
  entity      String
  entityId    String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  admin       AdminUser? @relation(fields: [adminId], references: [id])

  @@index([entity, entityId])
  @@index([adminId])
  @@index([createdAt])
}

model ConsentRecord {
  id          String   @id @default(cuid())
  userId      String
  consentType String
  version     String   @default("1.0")
  granted     Boolean  @default(true)
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
