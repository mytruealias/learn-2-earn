{
  "name": "learn-2-earn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "build": "prisma generate && npx tsx prisma/fix-migration.ts && prisma migrate deploy && next build && npx tsx prisma/seed.ts && npx tsx prisma/seed-recovery.ts",
    "start": "next start -p 5000 -H 0.0.0.0",
    "lint": "eslint",
    "test": "npm run test:api && npm run test:e2e",
    "test:api": "vitest run",
    "test:api:watch": "vitest",
    "test:e2e": "playwright test e2e/city-pin.spec.ts e2e/learner-flow.spec.ts e2e/payout-approval.spec.ts",
    "test:e2e:ui": "playwright test e2e/admin.spec.ts",
    "test:all": "npm run test && npm run test:e2e:ui"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0",
    "@playwright/test": "^1.58.2",
    "@prisma/client": "6.1.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "next": "^15.5.15",
    "openai": "^6.33.0",
    "prisma": "6.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "stripe": "^21.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "^15.5.15",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "minimatch@3": "3.1.4",
    "minimatch@9": "9.0.7",
    "flatted": "3.4.2",
    "picomatch@2": "2.3.2",
    "picomatch@4": "4.0.4"
  }
}
